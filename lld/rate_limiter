# **2️⃣ Staff-Level In-Memory File System (Ruby OOP, Versioning, Permissions, Path Service)**

```ruby
# --- Permission Manager ---
class PermissionManager
  def initialize
    @permissions = {} # user_id => role
  end

  def set_permission(user_id, role)
    @permissions[user_id] = role
  end

  def get_role(user_id)
    @permissions[user_id] || :none
  end

  def allow?(user_id, action)
    role = get_role(user_id)
    case role
    when :owner
      true
    when :write
      action != :read
    when :read
      action == :read
    else
      false
    end
  end
end

# --- Node Hierarchy ---
class Node
  attr_accessor :name, :parent, :permissions

  def initialize(name, parent=nil)
    @name = name
    @parent = parent
    @permissions = PermissionManager.new
  end

  def path
    return "/" if parent.nil?
    parent_path = parent.path == "/" ? "" : parent.path
    "#{parent_path}/#{name}"
  end
end

class FileNode < Node
  attr_accessor :versions

  def initialize(name, parent=nil)
    super(name, parent)
    @versions = []
  end

  def write(content, user_id=nil)
    check_permission(user_id, :write)
    @versions << content
  end

  def read(user_id=nil)
    check_permission(user_id, :read)
    raise FileNotFoundError, "File has no versions" if @versions.empty?
    @versions.last
  end

  def rollback(version_index)
    raise InvalidVersionError, "Invalid version" if version_index < 0 || version_index >= @versions.size
    @versions = @versions[0..version_index]
  end

  private

  def check_permission(user_id, action)
    return if user_id.nil?
    raise PermissionDeniedError, "Permission denied for #{action}" unless permissions.allow?(user_id, action)
  end
end

class DirectoryNode < Node
  attr_accessor :children

  def initialize(name, parent=nil)
    super(name, parent)
    @children = {}
  end

  def add_node(node)
    raise NodeAlreadyExistsError, "Node already exists" if children.key?(node.name)
    children[node.name] = node
    node.parent = self
  end

  def get_node(name)
    children[name]
  end

  def list
    children.keys
  end
end

# --- Path Service ---
class PathService
  def initialize(root)
    @root = root
  end

  def find_node(path)
    parts = path.split("/").reject(&:empty?)
    node = @root
    parts.each do |part|
      node = node.get_node(part)
      raise FileNotFoundError, "Path not found: #{part}" if node.nil?
    end
    node
  end

  def find_parent(path)
    parts = path.split("/").reject(&:empty?)
    name = parts.pop
    parent = @root
    parts.each do |part|
      parent = parent.get_node(part)
      raise DirectoryNotFoundError, "Directory not found: #{part}" if parent.nil? || !parent.is_a?(DirectoryNode)
    end
    [parent, name]
  end
end

# --- File System ---
class FileSystem
  attr_accessor :root, :path_service

  def initialize
    @root = DirectoryNode.new("/")
    @path_service = PathService.new(@root)
  end

  def mkdir(path)
    parent, name = path_service.find_parent(path)
    raise NodeAlreadyExistsError, "Directory already exists" if parent.get_node(name)
    parent.add_node(DirectoryNode.new(name, parent))
  end

  def write_file(path, content, user_id=nil)
    parent, name = path_service.find_parent(path)
    node = parent.get_node(name)
    if node.nil?
      node = FileNode.new(name, parent)
      parent.add_node(node)
    end
    node.write(content, user_id)
  end

  def read_file(path, user_id=nil)
    node = path_service.find_node(path)
    raise FileNotFoundError, "Not a file" unless node.is_a?(FileNode)
    node.read(user_id)
  end

  def list_dir(path)
    node = path_service.find_node(path)
    raise DirectoryNotFoundError, "Not a directory" unless node.is_a?(DirectoryNode)
    node.list
  end
end
